# GitHub Personal Access Token. For repo-scoped runners: needs 'repo' scope.
# For org-scoped runners: also needs the 'admin:org' scope (classic PAT) or
# 'Administration: Read and write' permission on the org (fine-grained PAT).
GITHUB_ACCESS_TOKEN=ghp_your_token_here

# Target selection (mutually exclusive — set exactly one):
#   GITHUB_ORG=<org-slug>           for org-level runners (visible to all repos in the org)
#   GITHUB_REPOSITORY=owner/repo    for repo-level runners (visible to a single repo)
#
# When GITHUB_ORG is set, GITHUB_REPOSITORY is ignored (and vice versa).
# Pick org-level when you want runners to serve every repo under the org.
# Pick repo-level when the runner should only see a specific repo.
GITHUB_ORG=
GITHUB_REPOSITORY=

# Runner name prefix (optional, defaults to "runner")
RUNNER_NAME_PREFIX=runner

# Number of runner instances to spin up (optional, defaults to 1)
RUNNER_COUNT=1

# Runner labels (comma-separated, optional). The default below includes
# 'r3dlex-org' so existing `runs-on: self-hosted` workflows do NOT silently
# start landing on these org-level runners — workflows must opt in with
# `runs-on: r3dlex-org`. Change this to match your org / opt-in label.
RUNNER_LABELS=self-hosted,linux,x64,r3dlex-org

# Runner group (optional, defaults to "Default")
RUNNER_GROUP=Default

# Docker image for the runner (optional)
RUNNER_IMAGE=github-runner:latest
